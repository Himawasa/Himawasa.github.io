# ============================================
# ホワイトリスト方式（安全優先）
# まず全部除外 → 公開するものだけ許可
# ============================================

# まず全ファイルを除外
*

# --- ここから公開許可するファイル ---

# gitignore自身
!.gitignore

# ポートフォリオ本体
!index.html
!logo.png
!ogp.png
!profile.png

# kintone-dx提案ページ（フォルダごと許可）
!kintone-dx/
!kintone-dx/**

# shiftsync（フォルダごと許可）
!shiftsync/
!shiftsync/**

# 士業向けDXポートフォリオ（フォルダごと許可）
!pro-dx/
!pro-dx/**

# --- ここから明示的に除外（念のため） ---

# 個人情報・機密ファイル
開業届/
gas/
_backup/
HANDOVER.md
*.pdf
*.bak

# docs は原則除外。react-migration の計画書のみ公開
docs/*
!docs/react-migration/
!docs/react-migration/**

# Yoom導入支援LP
!yoom-lp/
!yoom-lp/**

# 医療機関向けDXソリューション
!medical-dx/
!medical-dx/**

# 社労士ポータル概略説明ページ
!sharoushi-portal/
!sharoushi-portal/**

# GCPインフラ提案書（内部資料のため非公開）
# proposal/ は追跡対象から除外済み（git rm --cached -r proposal/）

# 任用試験学習ページ（非公開リンク）
!ninyou/
!ninyou/**

# MochiSync リダイレクト（ドライブアプリ回避）
!mochisync/
!mochisync/**

# PDFuse Sync リダイレクト（ドライブアプリ回避）
!pdfuse/
!pdfuse/**
